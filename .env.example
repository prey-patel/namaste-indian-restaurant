# ==============================================================================
# Namaste Indian Restaurant - Environment Variable Configuration
# ==============================================================================

# PUBLIC CLIENT VARIABLES
# Accessible by browser code. Prefixed with NEXT_PUBLIC_.
NEXT_PUBLIC_SUPABASE_URL=https://trccyyalqgsjkuszaqhr.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# SECURE SERVER-ONLY VARIABLES
# WARNING: NEVER expose these to client-side code. Do NOT prefix with NEXT_PUBLIC_.
# Permits bypassing RLS policies (use only in secure server API, server actions, or cron)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Brevo SMTP API Key for transactional customer emails
BREVO_API_KEY=your-brevo-key-here

# Telegram Bot API token for admin notification alerts
TELEGRAM_BOT_TOKEN=your-telegram-token-here

# Telegram Channel/Group Chat ID where notifications are dispatched
TELEGRAM_ADMIN_CHAT_ID=your-telegram-chat-id-here

# Routing & geocoding api credentials (e.g. OpenRouteService / Google Maps)
ROUTING_PROVIDER_API_KEY=your-routing-key-here

# Secret key for hashing IP addresses (used for contact rate limiting)
CONTACT_IP_HASH_SECRET=your-contact-ip-hash-secret-here

# Secret key for hashing IP addresses (used for reservation rate limiting)
RESERVATION_IP_HASH_SECRET=your-reservation-ip-hash-secret-here

# Secret key for hashing IP addresses (used for order rate limiting)
ORDER_IP_HASH_SECRET=your-order-ip-hash-secret-here

